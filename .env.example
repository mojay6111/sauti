# ============================================================
# Sauti — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# API Keys — comma-separated list of valid keys
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SAUTI_API_KEYS=your-api-key-here,another-key-here

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://sauti.africa

# Environment
ENV=development   # development | production

# MLflow tracking (optional — for experiment tracking)
MLFLOW_TRACKING_URI=mlruns

# Label Studio (if using cloud version)
# LABEL_STUDIO_API_KEY=

# Twitter/X API (for data collection — Phase 2)
# TWITTER_BEARER_TOKEN=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=

# Telegram (for data collection — Phase 2)  
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# Database (Phase 2 — for API key management and user accounts)
# DATABASE_URL=sqlite:///./sauti.db
